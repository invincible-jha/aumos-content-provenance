# AumOS Content Provenance — Environment Variables
# Copy to .env and fill in values for local development

# ── Database ──────────────────────────────────────────────────────────────────
AUMOS_PROVENANCE_DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_provenance

# ── Kafka ─────────────────────────────────────────────────────────────────────
AUMOS_PROVENANCE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Keycloak / Auth ───────────────────────────────────────────────────────────
AUMOS_PROVENANCE_KEYCLOAK_URL=http://localhost:8080
AUMOS_PROVENANCE_KEYCLOAK_REALM=aumos
AUMOS_PROVENANCE_KEYCLOAK_CLIENT_ID=content-provenance

# ── C2PA Signing ──────────────────────────────────────────────────────────────
# Paths to PEM-formatted private key and certificate chain
AUMOS_PROVENANCE_C2PA_SIGNING_KEY_PATH=/run/secrets/c2pa_signing_key.pem
AUMOS_PROVENANCE_C2PA_CERT_CHAIN_PATH=/run/secrets/c2pa_cert_chain.pem
AUMOS_PROVENANCE_C2PA_SIGNING_ALGORITHM=Es256
AUMOS_PROVENANCE_ENABLE_C2PA_SIGNING=true

# ── Watermarking ──────────────────────────────────────────────────────────────
AUMOS_PROVENANCE_WATERMARK_METHOD=dwtDct
AUMOS_PROVENANCE_WATERMARK_STRENGTH=0.3
AUMOS_PROVENANCE_ENABLE_WATERMARKING=true

# ── Lineage ───────────────────────────────────────────────────────────────────
AUMOS_PROVENANCE_LINEAGE_MAX_DEPTH=10
AUMOS_PROVENANCE_ENABLE_LINEAGE_TRACKING=true

# ── Audit Export ──────────────────────────────────────────────────────────────
# S3-compatible bucket for court-admissible audit trail packages
AUMOS_PROVENANCE_AUDIT_EXPORT_BUCKET=aumos-audit-trails
AUMOS_PROVENANCE_AUDIT_EXPORT_PREFIX=provenance/
AUMOS_PROVENANCE_AUDIT_EXPORT_FORMAT=json

# ── License Compliance ────────────────────────────────────────────────────────
AUMOS_PROVENANCE_LICENSE_RISK_THRESHOLD=0.7

# ── Service ───────────────────────────────────────────────────────────────────
AUMOS_PROVENANCE_SERVICE_NAME=aumos-content-provenance
